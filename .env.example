# ---- Supabase (client-safe, exposed to browser) ----
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ---- Web Push (VAPID public key, client-safe) ----
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# ---- App config ----
VITE_APP_NAME=Stepathon
VITE_MAX_STEPS_PER_DAY=100000

# ===========================================================
# SERVER-ONLY — never prefix with VITE_, never ship to client.
# Set these in Supabase Edge Function secrets / Vercel env.
# ===========================================================
# SUPABASE_SERVICE_ROLE_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:admin@yourcompany.com
